# Wojakcoin wallet - Electrs REST API (wjk-electrs)
# Wojakcoin: pubKeyHash 0x49 (W), no SegWit, tx version 1, RPC 20760
NEXT_PUBLIC_ELECTRS_API_URL=https://api.wojakcoin.cash
NEXT_PUBLIC_NETWORK=mainnet
NEXT_PUBLIC_BLOCK_EXPLORER_URL=https://explorer.wojakcoin.cash

# Android (Capacitor): app uses NEXT_PUBLIC_ELECTRS_API_URL above (api.wojakcoin.cash).
# Optional: proxy host that exposes /api/electrs and /api/price for web/static builds.
# For current production routing use /wallet base path:
NEXT_PUBLIC_API_PROXY_URL=https://wojakcoin.cash/wallet
# Optional: dedicated price API host; if unset, uses NEXT_PUBLIC_API_PROXY_URL/web origin.
# NEXT_PUBLIC_PRICE_API_URL=https://wojakcoin.cash/wallet

# LiveCoinWatch API key for WJK price (web only; get one at https://www.livecoinwatch.com/tools/api)
LIVECOINWATCH_API_KEY=1af68037-18ea-4d5d-8950-75539b96ddba
